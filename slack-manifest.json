{
  "display_information": {
    "name": "LabOps Agent",
    "description": "Predictive reagent stockout agent for clinical labs",
    "background_color": "#0F6B45"
  },
  "features": {
    "bot_user": {
      "display_name": "LabOps Agent",
      "always_online": true
    }
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "chat:write",
        "channels:read",
        "channels:history",
        "groups:read",
        "groups:history",
        "im:write",
        "users:read",
        "users:read.email",
        "team:read",
        "app_mentions:read",
        "canvases:read",
        "canvases:write",
        "search:read"
      ]
    }
  },
  "settings": {
    "interactivity": {
      "is_enabled": true
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
