# LabOps Agent — Environment Variables Template
# Copy to .env and fill with real values. NEVER commit .env.
#
# Database: choose ONE backend
#   Option A (cloud): SUPABASE_URL + SUPABASE_KEY
#   Option B (local/Docker): DATABASE_URL (postgres://...)

# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_SIGNING_SECRET=your-signing-secret
LABOPS_ALERTS_CHANNEL=#labops-alerts
LABOPS_ALERTS_CHANNEL_ID=C-your-channel-id

# Supabase (cloud)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-key

# PostgreSQL (local / Docker)
# DATABASE_URL=postgres://labops:labops@localhost:5432/labops

# Environment
# Set to 'development' to disable Slack token verification (local testing only)
# ENV=development

# Anthropic / Claude API
ANTHROPIC_API_KEY=sk-ant-your-api-key
CLAUDE_MODEL=claude-sonnet-4-6

