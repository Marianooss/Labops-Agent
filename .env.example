# LabOps Agent — Environment Variables Template
# Copy to .env and fill with real values. NEVER commit .env.
#
# Database: choose ONE backend
#   Option A (cloud): SUPABASE_URL + SUPABASE_KEY
#   Option B (local/Docker): DATABASE_URL (postgres://...)

# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_SIGNING_SECRET=your-signing-secret
LABOPS_ALERTS_CHANNEL=#labops-alerts
LABOPS_ALERTS_CHANNEL_ID=C-your-channel-id

# Optional: Slack User Token (xoxp-) for search.messages
# search.messages requires a USER token, not a bot token.
# Generate at https://api.slack.com/apps > OAuth & Permissions > User Token Scopes > search:read
# SLACK_USER_TOKEN=xoxp-your-user-token

# Backend URL — MUST be public HTTPS for the forecast chart to render in Slack.
# Slack fetches `image` blocks from its own servers, so localhost/http never shows.
#   - Deployed (Render/Railway/Fly): set to https://<service>.onrender.com
#   - Local demo: run a tunnel and paste its URL, e.g.
#       cloudflared tunnel --url http://localhost:8000
#       BACKEND_URL=https://<random>.trycloudflare.com
# If left blank/localhost, the agent falls back to native Block Kit fields
# (the chart is omitted, never shown broken).
# BACKEND_URL=

# Set RUN_SOCKET_MODE=1 to co-host Socket Mode inside the FastAPI web service
# (used on Render/Railway/Fly so one persistent host serves chart + websocket).
# Leave unset locally if you run `python backend/slack_client.py` separately.
# RUN_SOCKET_MODE=1

# Supabase (cloud)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-key

# PostgreSQL (local / Docker)
# DATABASE_URL=postgres://labops:labops@localhost:5432/labops

# Environment
# Set to 'development' to disable Slack token verification (local testing only)
# ENV=development

# Anthropic / Claude API
ANTHROPIC_API_KEY=sk-ant-your-api-key
CLAUDE_MODEL=claude-sonnet-4-6

